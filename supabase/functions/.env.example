# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cloudbeds
CLOUDBEDS_API_KEY=your_cloudbeds_api_key_here

# Stripe
# JSON object mapping aliases to Stripe secret keys, for example:
# {"margo_main":"sk_live_...","riad_massiba":"sk_live_..."}
STRIPE_SECRET_KEYS_JSON={"default":"sk_test_your_secret_key"}
