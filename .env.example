# Supabase Configuration
# Get these values from https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_PROJECT_ID="your_supabase_project_id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_public_key"

# Optional aliases for local scripts
SUPABASE_PROJECT_ID="your_supabase_project_id"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_public_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
SUPABASE_ACCESS_TOKEN="your_supabase_cli_or_user_access_token"
CLOUDBEDS_API_KEY="your_cloudbeds_api_key"

# Stripe Edge Functions
# JSON object mapping aliases to Stripe secret keys, for example:
# {"margo_main":"sk_live_...","riad_massiba":"sk_live_..."}
STRIPE_SECRET_KEYS_JSON='{"default":"sk_test_your_secret_key"}'
